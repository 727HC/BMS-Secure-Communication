# Cloud Agent 환경변수 템플릿
# 사용: cp .env.example .env 후 실제 값 채우기
# .env는 git-ignored — 절대 커밋하지 말 것

# ============================================================
# 서버 설정
# ============================================================
PORT=3002
# 공개 노출 시 BIND_HOST=0.0.0.0, 기본은 127.0.0.1
# BIND_HOST=127.0.0.1
NODE_ENV=development

# ============================================================
# API 보안
# ============================================================
# H-6: 강력한 랜덤 값 필수 — openssl rand -hex 32 로 생성
CLOUD_AGENT_API_KEY=CHANGE_ME_RANDOM_32_BYTES

# M-2: CORS 허용 오리진 (콤마 구분). 미설정 시 모든 cross-origin 차단
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# H-2: rate limit (분당 요청 수, 기본 300)
# RATE_LIMIT_MAX=300

# ============================================================
# MongoDB
# ============================================================
# H-8: production에서는 credentials 필수 포함 (user:pass@host)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=battery_passport

# ============================================================
# Fabric 연결
# ============================================================
FABRIC_CHANNEL=passportchannel
FABRIC_CONTRACT=passport-contract
FABRIC_MSP=ManufacturerMSP
FABRIC_IDENTITY=admin

# C-6: LEGACY_DEFAULT_SECRET 하드코딩 fallback 제거됨 — 반드시 설정 필요
# CA_ADMIN_PASSWORD (passport-network/.env)와 동일해야 함
FABRIC_ADMIN_SECRET=MUST_MATCH_CA_ADMIN_PASSWORD

# Fabric CA 접속 정보
FABRIC_CA_HOSTNAME=ca.manufacturer.battery.com
FABRIC_CA_PORT=7054
FABRIC_CA_NAME=ca-manufacturer

# H-7: TLS verify — production은 항상 true 강제됨
# FABRIC_CA_TLS_VERIFY=true

# H-7: CA 인증서 파일 경로 (TLS verify 활성 시 필수)
# FABRIC_CA_CERT_PATH=/path/to/ca-cert.pem

# 지갑 경로 (상대 경로는 cloud-agent 디렉토리 기준)
# FABRIC_WALLET_PATH=./wallet

# 연결 프로파일 경로 (기본: passport-network에서 자동 탐색)
# FABRIC_CCP_PATH=/path/to/connection-manufacturer.json

# Docker 환경에서는 false
FABRIC_DISCOVERY_AS_LOCALHOST=true
