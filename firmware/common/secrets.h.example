/**
 * @file    secrets.h
 * @brief   Pre-Shared Key and Ed25519 DID Seed
 *
 * @warning Do NOT commit secrets.h to version control.
 *          .gitignore already excludes **/secrets.h.
 *
 * Setup:
 *   1. Copy this file:  cp secrets.h.example secrets.h
 *   2. Fill in key values below
 *   3. Copy to both build trees:
 *        BMU_BMS_S32K344/src/common/secrets.h
 *        CMU_BMS_S32K144/src/common/secrets.h  (PSK only, EdDSA_Seed ignored)
 *
 * Key generation:
 *   - Development: any 16-byte hex for PSK, any 32-byte string for EdDSA_Seed
 *   - Production:  use hardware RNG (e.g. openssl rand -hex 16)
 *                  EdDSA_Seed must match the DID registered in VON/Indy ledger
 *
 * Key rotation:
 *   - PSK: reflash both BMU and CMU with new PSK, then reboot
 *   - EdDSA_Seed: re-register DID on Indy ledger, update config.env BMU_DID
 *
 * Production roadmap:
 *   - Load PSK from HSE NVM key slot (S32K344) / CSEc NVM (S32K144)
 *   - Provision via secure JTAG during manufacturing
 *   - This file becomes unnecessary once NVM provisioning is implemented
 */

#ifndef SECRETS_H
#define SECRETS_H

/* bms_protocol.h is already included by main.c before this file */

/*============================================================================
 *  AES-128 Pre-Shared Key (16 bytes)
 *  Shared between BMU and CMU for ECDH key exchange and CMAC.
 *  Used as KDF input: SessionKey = CMAC(PSK, Label || UID || Seed || Counter)
 *============================================================================*/
static const uint8 PreSharedKey[AES_KEY_SIZE] = {
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
};

/*============================================================================
 *  Ed25519 DID Seed (32 bytes) — BMU only
 *  Deterministic seed for TweetNaCl crypto_sign_keypair().
 *  CMU does not use this (CMU only generates CMAC, BMU signs for blockchain).
 *  Must match public key registered in VON/Indy ledger for DID verification.
 *============================================================================*/
static const uint8 EdDSA_Seed[32] = {
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
};

#endif /* SECRETS_H */
