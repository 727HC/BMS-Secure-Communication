# BMS Project Configuration
# Source this file: source config.env
# Copy this file to config.env and fill in your environment values.

# === COM Ports ===
BMU_COM=COM4                # BMU 시리얼 포트 (PC에서 확인)
CMU_COM=COM5                # CMU 시리얼 포트 (PC에서 확인)

# === Baud Rates ===
BMU_BAUD=28800              # BMU LPUART6 debug output
CMU_UART_BAUD=9600          # CMU LPUART1 data input (dataProcess.py → CMU)

# === PEmicro Debugger ===
BMU_DEVICE=NXP_S32K3xx_S32K344
BMU_INTERFACE=USBMULTILINK
BMU_PORT=CHANGE_ME          # pegdbserver_console -listusbmultilink 으로 확인

CMU_DEVICE=NXP_S32K1xx_S32K144F512M15
CMU_INTERFACE=OPENSDA
CMU_PORT=CHANGE_ME          # pegdbserver_console -listopensda 으로 확인

# === Paths (S32DS 설치 경로에 맞게 수정) ===
TOOLCHAIN_PATH="/c/NXP/S32DS.3.6.1/S32DS/build_tools/gcc_v10.2/gcc-10.2-arm32-eabi/bin"
MAKE_PATH="/c/NXP/S32DS.3.6.1/S32DS/build_tools/msys32/usr/bin"
PEG_PATH="/c/NXP/S32DS.3.6.1/eclipse/plugins/com.pemicro.debug.gdbjtag.pne_5.9.2.202409131555/win32/pegdbserver_console.exe"

# === Build Outputs ===
BMU_ELF="BMU_BMS_S32K344/Debug_FLASH/BMU_BMS_S32K344.elf"
CMU_ELF="CMU_BMS_S32K144/Debug_FLASH/CMU_BMS_S32K144.elf"

# === Build Mode ===
# BMS_MODE_PLAIN_CAN | BMS_MODE_CMAC | BMS_MODE_EDDSA
BMS_MODE=BMS_MODE_EDDSA

# === Blockchain ===
BMU_DID=                       # BMU DID for signature verification (e.g. MPGsQGEaPz9qcySnxfFt4B)

# === Simulator ===
SIM_UDP_PORT=5005
