# BMS MCP Monitor — Environment Variables

# Agent API
AGENT_URL=http://localhost:3001
# Optional: pre-provisioned ManufacturerMSP/RegulatorMSP JWT for read-only GET /api/audit.
# MCP never logs in with stored credentials; leave blank to use local logs/audit.log fallback.
PASSPORT_AUDIT_TOKEN=

# Fabric Network
FABRIC_CHANNEL=passportchannel
FABRIC_CONTRACT=passport-contract
FABRIC_IDENTITY=admin
FABRIC_ORG=1
FABRIC_DISCOVERY_AS_LOCALHOST=true
FABRIC_CA_TLS_VERIFY=true

# Fabric Orgs
FABRIC_ORG1_MSP=ManufacturerMSP
FABRIC_ORG1_DOMAIN=manufacturer.battery.com
FABRIC_ORG1_CA_NAME=ca-manufacturer
FABRIC_ORG1_CA_PORT=7054
FABRIC_ORG1_PEER_ENDPOINT=localhost:7051

FABRIC_ORG2_MSP=EVManufacturerMSP
FABRIC_ORG2_DOMAIN=evmanufacturer.battery.com
FABRIC_ORG2_CA_NAME=ca-evmanufacturer
FABRIC_ORG2_CA_PORT=8054
FABRIC_ORG2_PEER_ENDPOINT=localhost:9051

FABRIC_ORG3_MSP=ServiceMSP
FABRIC_ORG3_DOMAIN=service.battery.com
FABRIC_ORG3_CA_NAME=ca-service
FABRIC_ORG3_CA_PORT=9054
FABRIC_ORG3_PEER_ENDPOINT=localhost:11051

FABRIC_ORG4_MSP=RegulatorMSP
FABRIC_ORG4_DOMAIN=regulator.battery.com
FABRIC_ORG4_CA_NAME=ca-regulator
FABRIC_ORG4_CA_PORT=10054
FABRIC_ORG4_PEER_ENDPOINT=localhost:13051

# VON Network
VON_URL=http://localhost:9000

# ACA-Py
ACAPY_ADMIN_URL=http://localhost:8031

# BMU Thresholds
BMU_SOC_MIN=10
BMU_SOC_MAX=95
# Pack voltage (11S): cell min/max * 11
BMU_VOLTAGE_MIN=27.5
BMU_VOLTAGE_MAX=47.85
BMU_TEMP_MIN=0
BMU_TEMP_MAX=60
# Warn when a BMU freshness counter jumps by more than this amount between samples.
BMU_FRESHNESS_GAP_WARN=1000

# Log file path (structured JSON logs from bmu-agent)
LOG_FILE_PATH=../logs/agent.log
# Audit log path used when PASSPORT_AUDIT_TOKEN is not configured.
PASSPORT_AUDIT_LOG_PATH=../logs/audit.log
