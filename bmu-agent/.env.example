# ============================================================
# Battery Passport Agent — Environment Variables
# Copy to .env and fill in values
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3001

# --- JWT ---
JWT_SECRET=REMOVED_SECRET_ROTATED_2026_04_18
JWT_EXPIRY=24h

# --- ACA-Py (Aries Cloud Agent) ---
ACA_PY_URL=http://localhost:8031

# --- Fabric Network ---
FABRIC_CHANNEL=passportchannel
FABRIC_CONTRACT=passport-contract
FABRIC_IDENTITY=admin
FABRIC_ADMIN_SECRET=REMOVED_SECRET_ROTATED_2026_04_18
FABRIC_ORG=1
FABRIC_WALLET_PATH=
FABRIC_CA_TLS_VERIFY=true
FABRIC_DISCOVERY_AS_LOCALHOST=true

# --- Fabric Org 1: Manufacturer ---
FABRIC_ORG1_MSP=ManufacturerMSP
FABRIC_ORG1_DOMAIN=manufacturer.battery.com
FABRIC_ORG1_CA_NAME=ca-manufacturer
FABRIC_ORG1_CA_PORT=7054
FABRIC_ORG1_PEER_ENDPOINT=localhost:7051
FABRIC_ORG1_CCP_PATH=

# --- Fabric Org 2: EV Manufacturer ---
FABRIC_ORG2_MSP=EVManufacturerMSP
FABRIC_ORG2_DOMAIN=evmanufacturer.battery.com
FABRIC_ORG2_CA_NAME=ca-evmanufacturer
FABRIC_ORG2_CA_PORT=8054
FABRIC_ORG2_PEER_ENDPOINT=localhost:9051
FABRIC_ORG2_CCP_PATH=

# --- Fabric Org 3: Service ---
FABRIC_ORG3_MSP=ServiceMSP
FABRIC_ORG3_DOMAIN=service.battery.com
FABRIC_ORG3_CA_NAME=ca-service
FABRIC_ORG3_CA_PORT=9054
FABRIC_ORG3_PEER_ENDPOINT=localhost:11051
FABRIC_ORG3_CCP_PATH=

# --- Fabric Org 4: Regulator ---
FABRIC_ORG4_MSP=RegulatorMSP
FABRIC_ORG4_DOMAIN=regulator.battery.com
FABRIC_ORG4_CA_NAME=ca-regulator
FABRIC_ORG4_CA_PORT=10054
FABRIC_ORG4_PEER_ENDPOINT=localhost:13051
FABRIC_ORG4_CCP_PATH=

# --- VON Network ---
VON_WEBSERVER_URL=http://localhost:9000

# --- ACA-Py Container ---
ACAPY_INBOUND_PORT=8030
ACAPY_ADMIN_PORT=8031
ACAPY_SEED=REMOVED_SEED_ROTATED_2026_04_18
ACAPY_WALLET_NAME=bmu_wallet2
ACAPY_WALLET_KEY=REMOVED_WALLET_KEY_ROTATED_2026_04_18
ACAPY_DOCKER_NETWORK=von_von

# --- DID Admin ---
ADMIN_API_KEY=

# --- Pagination ---
DEFAULT_PAGE_SIZE=100
MAX_PAGE_SIZE=500

# --- Cache ---
DID_CACHE_TTL_MS=300000
