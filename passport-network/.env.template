# Passport Network 환경변수 템플릿
# 사용: cp .env.template .env 후 실제 값 채우기
# .env 파일은 git에 커밋하지 말 것 (.gitignore로 차단됨)

# ============================================================
# Fabric image pins
# ============================================================
# latest 태그 금지. Fabric 2.5 LTS 계열과 Fabric CA 1.5 계열을 명시한다.
FABRIC_VERSION=2.5
FABRIC_CA_VERSION=1.5

# ============================================================
# Fabric CA 부트스트랩 크레덴셜
# ============================================================
# compose-ca.yaml에서 모든 CA가 사용
# 운영 환경에서는 CA별 개별 시크릿으로 분리 권장
CA_ADMIN_USER=ca-admin
CA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_AT_LEAST_20_CHARS
CA_PASSWORD_ATTEMPTS=10

# ============================================================
# Fabric CA 등록/등록해제 identity secrets
# ============================================================
# organizations/registerEnroll.sh에서 사용.
# 운영 환경에서는 각 identity별 고유 난수 secret으로 교체한다.
MANUFACTURER_PEER0_SECRET=CHANGE_ME_MANUFACTURER_PEER0_SECRET
MANUFACTURER_USER1_SECRET=CHANGE_ME_MANUFACTURER_USER1_SECRET
MANUFACTURER_ADMIN_SECRET=CHANGE_ME_MANUFACTURER_ADMIN_SECRET

EVMANUFACTURER_PEER0_SECRET=CHANGE_ME_EVMANUFACTURER_PEER0_SECRET
EVMANUFACTURER_USER1_SECRET=CHANGE_ME_EVMANUFACTURER_USER1_SECRET
EVMANUFACTURER_ADMIN_SECRET=CHANGE_ME_EVMANUFACTURER_ADMIN_SECRET

SERVICE_PEER0_SECRET=CHANGE_ME_SERVICE_PEER0_SECRET
SERVICE_USER1_SECRET=CHANGE_ME_SERVICE_USER1_SECRET
SERVICE_ADMIN_SECRET=CHANGE_ME_SERVICE_ADMIN_SECRET

REGULATOR_PEER0_SECRET=CHANGE_ME_REGULATOR_PEER0_SECRET
REGULATOR_USER1_SECRET=CHANGE_ME_REGULATOR_USER1_SECRET
REGULATOR_ADMIN_SECRET=CHANGE_ME_REGULATOR_ADMIN_SECRET

ORDERER_NODE_SECRET=CHANGE_ME_ORDERER_NODE_SECRET
ORDERER_ADMIN_SECRET=CHANGE_ME_ORDERER_ADMIN_SECRET

# ============================================================
# CouchDB 크레덴셜
# ============================================================
# compose-couch.yaml에서 4개 CouchDB 인스턴스 공통 사용
COUCHDB_USER=couch-admin
COUCHDB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_AT_LEAST_20_CHARS
